# ============================================================
# Plant Quality — Local Docker Development Environment
# ============================================================
# This file is used *only* by Docker Compose for local dev.
# No paid services needed; everything runs inside containers.
# ============================================================

NODE_ENV=development
PORT=3000

# NextAuth (Auth.js v5)
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Prisma / PostgreSQL (via internal Docker network)
DATABASE_URL="postgresql://postgres:postgres@db:5432/plantx"

# Email (Mailpit inside Docker)
EMAIL_SERVER='{"host":"plantx-mail","port":1025}'
EMAIL_FROM="noreply@plantquality.com"

# S3-compatible Object Storage (MinIO inside Docker)
R2_ACCOUNT_ID="local"
R2_ACCESS_KEY_ID="minioadmin"
R2_SECRET_ACCESS_KEY="minioadmin"
R2_BUCKET_NAME="plant-quality"
R2_PUBLIC_URL="http://host.docker.internal:9000/plant-quality"

# AI Provider — DeepSeek (or another OpenAI-compatible API)
AI_BASE_URL="https://api.deepseek.com/v1"
AI_MODEL="deepseek-chat"
AI_API_KEY=""
