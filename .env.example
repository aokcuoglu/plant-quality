DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Magic link email. In development, links are printed to the server console
# when EMAIL_SERVER is omitted.
EMAIL_SERVER='{"host":"localhost","port":1025}'
EMAIL_FROM="noreply@plantquality.com"

# Cloudflare R2 / S3-compatible object storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# AI provider. Defaults are compatible with DeepSeek's OpenAI-style API.
AI_API_KEY=""
AI_BASE_URL="https://api.deepseek.com/v1"
AI_MODEL="deepseek-chat"
