generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyType {
  OEM
  SUPPLIER
}

enum Role {
  ADMIN
  QUALITY_ENGINEER
  VIEWER
}

enum Plan {
  BASIC
  PRO
}

enum NotificationType {
  INFO
  REVISION
  NEW_DEFECT
  SLA_DUE_SOON
  SLA_ESCALATION
  PPAP_REQUIRED
  PPAP_SUBMITTED
  PPAP_APPROVED
  PPAP_REJECTED
  IQC_FAILED
  FMEA_HIGH_RPN
  FIELD_DEFECT_CREATED
  FIELD_DEFECT_ASSIGNED
  FIELD_DEFECT_CONVERTED_TO_8D
}

enum ReviewCommentStatus {
  OPEN
  RESOLVED
}

enum DefectEventType {
  CREATED
  EIGHT_D_STARTED
  EIGHT_D_STEP_SAVED
  EIGHT_D_SUBMITTED
  REVIEW_COMMENT_ADDED
  REVIEW_COMMENT_RESPONDED
  REVIEW_COMMENT_RESOLVED
  REVIEW_COMMENT_REOPENED
  REVISION_REQUESTED
  APPROVED
  OWNER_CHANGED
  SUPPLIER_ASSIGNEE_CHANGED
  DUE_DATE_CHANGED
  EVIDENCE_ADDED
  EVIDENCE_REMOVED
  PPAP_CREATED
  PPAP_SUBMITTED
  PPAP_APPROVED
  PPAP_REJECTED
  IQC_CREATED
  IQC_COMPLETED
  IQC_FAILED
  FMEA_CREATED
  FMEA_UPDATED
  FMEA_APPROVED
  FIELD_DEFECT_CREATED
  FIELD_DEFECT_STATUS_CHANGED
  FIELD_DEFECT_SUPPLIER_ASSIGNED
  FIELD_DEFECT_CONVERTED_TO_8D
  FIELD_DEFECT_COMMENT_ADDED
  FIELD_DEFECT_ATTACHMENT_ADDED
  FIELD_DEFECT_ATTACHMENT_REMOVED
  FIELD_DEFECT_CLOSED
  FIELD_DEFECT_CANCELLED
}

enum DefectStatus {
  OPEN
  IN_PROGRESS
  WAITING_APPROVAL
  RESOLVED
  REJECTED
}

enum ActionOwner {
  OEM
  SUPPLIER
  NONE
}

enum EightDSection {
  D3
  D5
  D6
  D7
}

enum PpapLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
}

enum PpapStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  REVISED
}

enum PpapSubmissionRequirement {
  DESIGN_RECORDS
  ENGINEERING_CHANGE_DOCUMENTS
  CUSTOMER_ENGINEERING_APPROVAL
  DESIGN_FMEA
  PROCESS_FLOW_DIAGRAM
  PROCESS_FMEA
  CONTROL_PLAN
  MEASUREMENT_SYSTEM_ANALYSIS
  DIMENSIONAL_RESULTS
  MATERIAL_PERFORMANCE_RESULTS
  INITIAL_PROCESS_STUDY
  QUALIFIED_LABORATORY_DOCUMENTATION
  APPEARANCE_APPROVAL_REPORT
  SAMPLE_PRODUCTION_PARTS
  MASTER_SAMPLE
  CHECKING_ASSIST
  PART_SUBMISSION_WARRANT
}

enum IqcStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  CONDITIONALLY_ACCEPTED
}

enum FmeaStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REVISED
}

enum FmeaType {
  DESIGN
  PROCESS
}

enum FieldDefectSource {
  FIELD
  SERVICE
  CUSTOMER
  DEALER
  INTERNAL
}

enum FieldDefectSeverity {
  MINOR
  MAJOR
  CRITICAL
}

enum FieldDefectStatus {
  DRAFT
  OPEN
  UNDER_REVIEW
  SUPPLIER_ASSIGNED
  LINKED_TO_8D
  CLOSED
  CANCELLED
}

model Company {
  id           String        @id @default(uuid())
  name         String
  type         CompanyType
  taxNumber    String?
  users        User[]
  defectsAsOem Defect[]      @relation("OemDefects")
  defectsAsSup Defect[]      @relation("SupplierDefects")
  ppapAsOem    PpapSubmission[] @relation("OemPpapSubmissions")
  ppapAsSup    PpapSubmission[] @relation("SupplierPpapSubmissions")
  iqcAsOem     IqcReport[]   @relation("OemIqcReports")
  iqcAsSup     IqcReport[]   @relation("SupplierIqcReports")
  fmeaAsOem    Fmea[]        @relation("OemFmeas")
  fmeaAsSup    Fmea[]        @relation("SupplierFmeas")
  fieldDefectsAsOem FieldDefect[] @relation("FieldDefectOem")
  fieldDefectsAsSup FieldDefect[] @relation("FieldDefectSupplier")
  createdAt    DateTime      @default(now())

  @@map("companies")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  name           String?
  emailVerified  DateTime?
  image          String?
  role           Role            @default(VIEWER)
  plan           Plan            @default(BASIC)
  companyId      String?
  company        Company?        @relation(fields: [companyId], references: [id])
  accounts       Account[]
  sessions       Session[]
  reviewComments ReviewComment[]
  resolvedReviewComments ReviewComment[] @relation("ReviewCommentResolvedBy")
  approvedReports EightDReport[] @relation("EightDApprovedBy")
  rejectedReports EightDReport[] @relation("EightDRejectedBy")
  ownedDefects Defect[] @relation("DefectOemOwner")
  assignedDefects Defect[] @relation("DefectSupplierAssignee")
  defectEvents    DefectEvent[]  @relation("DefectEventActor")
  uploadedEvidence DefectEvidence[] @relation("DefectEvidenceUploadedBy")
  notifications  Notification[]
  ownedPpaps     PpapSubmission[] @relation("PpapOemOwner")
  assignedPpaps  PpapSubmission[] @relation("PpapSupplierAssignee")
  approvedPpaps  PpapSubmission[] @relation("PpapApprovedBy")
  rejectedPpaps  PpapSubmission[] @relation("PpapRejectedBy")
  ppapEvidenceUploads PpapEvidence[] @relation("PpapEvidenceUploadedBy")
  ppapCommentResolved  PpapReviewComment[] @relation("PpapCommentResolvedBy")
  ppapCommentAuthored  PpapReviewComment[] @relation("PpapCommentAuthor")
  ppapEventActors PpapEvent[] @relation("PpapEventActor")
  iqcInspections IqcReport[] @relation("IqcInspector")
  iqcEventActors IqcEvent[] @relation("IqcEventActor")
  fmeaResponsible Fmea[] @relation("FmeaResponsible")
  fmeaApprovedBy Fmea[] @relation("FmeaApprovedBy")
  fmeaEventActors FmeaEvent[] @relation("FmeaEventActor")
  createdFieldDefects     FieldDefect[] @relation("FieldDefectCreatedBy")
  updatedFieldDefects     FieldDefect[] @relation("FieldDefectUpdatedBy")
  convertedFieldDefects   FieldDefect[] @relation("FieldDefectConvertedBy")
  fieldDefectAttachments  FieldDefectAttachment[] @relation("FieldDefectAttachmentUploadedBy")
  fieldDefectComments     FieldDefectComment[] @relation("FieldDefectCommentAuthor")
  fieldDefectEvents       FieldDefectEvent[] @relation("FieldDefectEventActor")
  createdAt      DateTime        @default(now())

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Defect {
  id           String        @id @default(uuid())
  oemId        String
  oem          Company       @relation("OemDefects", fields: [oemId], references: [id])
  supplierId   String
  supplier     Company       @relation("SupplierDefects", fields: [supplierId], references: [id])
  partNumber   String
  description  String
  status       DefectStatus  @default(OPEN)
  imageUrls    String[]
  oemOwnerId   String?       @map("oem_owner_id")
  oemOwner     User?         @relation("DefectOemOwner", fields: [oemOwnerId], references: [id])
  supplierAssigneeId String? @map("supplier_assignee_id")
  supplierAssignee   User?   @relation("DefectSupplierAssignee", fields: [supplierAssigneeId], references: [id])
  supplierResponseDueAt DateTime? @map("supplier_response_due_at")
  eightDSubmissionDueAt DateTime? @map("eight_d_submission_due_at")
  oemReviewDueAt        DateTime? @map("oem_review_due_at")
  revisionDueAt         DateTime? @map("revision_due_at")
  currentActionOwner    ActionOwner @default(SUPPLIER) @map("current_action_owner")
  eightDReport EightDReport?
  events       DefectEvent[]
  evidences    DefectEvidence[]
  ppap         PpapSubmission?
  iqcReport    IqcReport?
  fmea         Fmea?
  linkedFieldDefect FieldDefect?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  resolvedAt   DateTime?

  @@map("defects")
}

model EightDReport {
  id             String          @id @default(uuid())
  defectId       String          @unique
  defect         Defect          @relation(fields: [defectId], references: [id])
  d2_problem     String?
  d4_rootCause   String?
  d5_d6_action   String?
  d8_recognition String?
  submittedAt    DateTime?
  lastSubmittedAt DateTime?       @map("last_submitted_at")
  lastReviewedAt  DateTime?       @map("last_reviewed_at")
  approvedAt      DateTime?       @map("approved_at")
  approvedById    String?         @map("approved_by_id")
  approvedBy      User?           @relation("EightDApprovedBy", fields: [approvedById], references: [id])
  rejectedAt      DateTime?       @map("rejected_at")
  rejectedById    String?         @map("rejected_by_id")
  rejectedBy      User?           @relation("EightDRejectedBy", fields: [rejectedById], references: [id])
  revisionNo      Int             @default(0) @map("revision_no")
  updatedAt      DateTime        @updatedAt
  reviewComments ReviewComment[]

  // Structured JSONB fields (IATF 16949)
  team               Json?   @map("d1_team")
  containmentActions Json?   @map("d3_containment")
  d5Actions          Json?   @map("d5_actions")
  d6Actions          Json?   @map("d6_actions")
  d7Impacts          Json?   @map("d7_impacts")
  d7Preventive       String? @map("d7_preventive")

  @@map("eight_d_reports")
}

model ReviewComment {
  id        String       @id @default(uuid())
  reportId  String       @map("report_id")
  report    EightDReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  stepId    String       @map("step_id")
  comment   String
  status    ReviewCommentStatus @default(OPEN)
  supplierResponse String?      @map("supplier_response")
  resolvedAt DateTime?          @map("resolved_at")
  resolvedById String?          @map("resolved_by_id")
  resolvedBy User?              @relation("ReviewCommentResolvedBy", fields: [resolvedById], references: [id])
  authorId  String       @map("author_id")
  author    User         @relation(fields: [authorId], references: [id])
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("review_comments")
}

model DefectEvent {
  id        String          @id @default(uuid())
  defectId  String          @map("defect_id")
  defect    Defect          @relation(fields: [defectId], references: [id], onDelete: Cascade)
  type      DefectEventType
  actorId   String?         @map("actor_id")
  actor     User?           @relation("DefectEventActor", fields: [actorId], references: [id])
  metadata  Json?
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([defectId, createdAt])
  @@map("defect_events")
}

model DefectEvidence {
  id           String       @id @default(cuid())
  defectId     String       @map("defect_id")
  defect       Defect       @relation(fields: [defectId], references: [id], onDelete: Cascade)
  section      EightDSection
  storageKey   String       @map("storage_key")
  fileName     String       @map("file_name")
  mimeType     String       @map("mime_type")
  sizeBytes    Int          @map("size_bytes")
  uploadedById String       @map("uploaded_by_id")
  uploadedBy   User         @relation("DefectEvidenceUploadedBy", fields: [uploadedById], references: [id])
  companyId    String       @map("company_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  deletedAt    DateTime?    @map("deleted_at")

  @@index([defectId, section])
  @@index([companyId, createdAt])
  @@map("defect_evidence")
}

model PpapSubmission {
  id                    String        @id @default(uuid())
  partNumber           String        @map("part_number")
  partName             String        @map("part_name")
  revision              String        @default("A") @map("revision")
  level                 PpapLevel     @default(LEVEL_3) @map("level")
  status                PpapStatus    @default(DRAFT)
  oemId                 String        @map("oem_id")
  oem                   Company       @relation("OemPpapSubmissions", fields: [oemId], references: [id])
  supplierId            String        @map("supplier_id")
  supplier              Company       @relation("SupplierPpapSubmissions", fields: [supplierId], references: [id])
  oemOwnerId            String?       @map("oem_owner_id")
  oemOwner              User?         @relation("PpapOemOwner", fields: [oemOwnerId], references: [id])
  supplierAssigneeId    String?       @map("supplier_assignee_id")
  supplierAssignee      User?         @relation("PpapSupplierAssignee", fields: [supplierAssigneeId], references: [id])
  defectId              String?       @unique @map("defect_id")
  defect                Defect?       @relation(fields: [defectId], references: [id])
  submittedAt           DateTime?     @map("submitted_at")
  reviewedAt            DateTime?     @map("reviewed_at")
  approvedAt            DateTime?     @map("approved_at")
  rejectedAt            DateTime?     @map("rejected_at")
  approvedById          String?       @map("approved_by_id")
  approvedBy            User?         @relation("PpapApprovedBy", fields: [approvedById], references: [id])
  rejectedById          String?       @map("rejected_by_id")
  rejectedBy            User?         @relation("PpapRejectedBy", fields: [rejectedById], references: [id])
  rejectionReason       String?       @map("rejection_reason")
  dueDate               DateTime?     @map("due_date")
  requirements          Json?         @map("requirements")
  notes                 String?       @map("notes")
  supplierNotes         String?       @map("supplier_notes")
  evidences             PpapEvidence[]
  reviewComments        PpapReviewComment[]
  events                PpapEvent[]
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  @@index([oemId, status])
  @@index([supplierId, status])
  @@index([defectId])
  @@map("ppap_submissions")
}

model PpapEvidence {
  id              String          @id @default(cuid())
  ppapId          String          @map("ppap_id")
  ppap            PpapSubmission  @relation(fields: [ppapId], references: [id], onDelete: Cascade)
  requirement     PpapSubmissionRequirement
  storageKey      String          @map("storage_key")
  fileName        String          @map("file_name")
  mimeType        String          @map("mime_type")
  sizeBytes       Int             @map("size_bytes")
  uploadedById    String          @map("uploaded_by_id")
  uploadedBy      User            @relation("PpapEvidenceUploadedBy", fields: [uploadedById], references: [id])
  companyId       String          @map("company_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  deletedAt       DateTime?       @map("deleted_at")

  @@index([ppapId, requirement])
  @@index([companyId, createdAt])
  @@map("ppap_evidence")
}

model PpapReviewComment {
  id               String       @id @default(uuid())
  ppapId           String       @map("ppap_id")
  ppap             PpapSubmission @relation(fields: [ppapId], references: [id], onDelete: Cascade)
  requirement      PpapSubmissionRequirement
  comment          String
  status           ReviewCommentStatus @default(OPEN)
  supplierResponse String?      @map("supplier_response")
  resolvedAt       DateTime?    @map("resolved_at")
  resolvedById     String?       @map("resolved_by_id")
  resolvedBy       User?        @relation("PpapCommentResolvedBy", fields: [resolvedById], references: [id])
  authorId         String       @map("author_id")
  author           User         @relation("PpapCommentAuthor", fields: [authorId], references: [id])
  createdAt        DateTime     @default(now()) @map("created_at")

  @@index([ppapId, status])
  @@map("ppap_review_comments")
}

model PpapEvent {
  id        String          @id @default(uuid())
  ppapId    String          @map("ppap_id")
  ppap      PpapSubmission  @relation(fields: [ppapId], references: [id], onDelete: Cascade)
  type      DefectEventType
  actorId   String?         @map("actor_id")
  actor     User?           @relation("PpapEventActor", fields: [actorId], references: [id])
  metadata  Json?
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([ppapId, createdAt])
  @@map("ppap_events")
}

model IqcReport {
  id                    String      @id @default(uuid())
  lotNumber             String      @map("lot_number")
  partNumber            String      @map("part_number")
  partName              String?     @map("part_name")
  quantity              Int         @default(0)
  quantityAccepted      Int         @default(0) @map("quantity_accepted")
  quantityRejected      Int         @default(0) @map("quantity_rejected")
  status                IqcStatus   @default(PENDING)
  oemId                 String      @map("oem_id")
  oem                   Company     @relation("OemIqcReports", fields: [oemId], references: [id])
  supplierId            String      @map("supplier_id")
  supplier              Company     @relation("SupplierIqcReports", fields: [supplierId], references: [id])
  inspectorId           String?     @map("inspector_id")
  inspector             User?       @relation("IqcInspector", fields: [inspectorId], references: [id])
  defectId              String?     @unique @map("defect_id")
  defect                Defect?     @relation(fields: [defectId], references: [id])
  inspectionDate        DateTime?   @map("inspection_date")
  measurements          Json?       @map("measurements")
  nonconformities       Json?       @map("nonconformities")
  dispositionNotes      String?     @map("disposition_notes")
  completedAt           DateTime?   @map("completed_at")
  events                IqcEvent[]
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  @@index([oemId, status])
  @@index([supplierId, status])
  @@index([defectId])
  @@map("iqc_reports")
}

model IqcEvent {
  id        String      @id @default(uuid())
  reportId  String      @map("report_id")
  report    IqcReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  type      DefectEventType
  actorId   String?     @map("actor_id")
  actor     User?       @relation("IqcEventActor", fields: [actorId], references: [id])
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([reportId, createdAt])
  @@map("iqc_events")
}

model Fmea {
  id                String     @id @default(uuid())
  title             String
  fmeaType          FmeaType   @default(PROCESS) @map("fmea_type")
  status            FmeaStatus @default(DRAFT)
  partNumber        String     @map("part_number")
  partName          String?    @map("part_name")
  processStep       String?    @map("process_step")
  oemId             String     @map("oem_id")
  oem               Company    @relation("OemFmeas", fields: [oemId], references: [id])
  supplierId        String     @map("supplier_id")
  supplier          Company    @relation("SupplierFmeas", fields: [supplierId], references: [id])
  responsibleId     String?    @map("responsible_id")
  responsible       User?      @relation("FmeaResponsible", fields: [responsibleId], references: [id])
  defectId          String?    @unique @map("defect_id")
  defect            Defect?    @relation(fields: [defectId], references: [id])
  rows              Json?      @map("rows")
  submittedAt       DateTime?  @map("submitted_at")
  reviewedAt        DateTime?  @map("reviewed_at")
  approvedAt        DateTime?  @map("approved_at")
  approvedById      String?    @map("approved_by_id")
  approvedBy        User?      @relation("FmeaApprovedBy", fields: [approvedById], references: [id])
  revisionNo        Int        @default(0) @map("revision_no")
  notes             String?    @map("notes")
  events            FmeaEvent[]
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@index([oemId, status])
  @@index([supplierId, status])
  @@index([defectId])
  @@map("fmeas")
}

model FmeaEvent {
  id        String      @id @default(uuid())
  fmeaId    String      @map("fmea_id")
  fmea      Fmea        @relation(fields: [fmeaId], references: [id], onDelete: Cascade)
  type      DefectEventType
  actorId   String?     @map("actor_id")
  actor     User?       @relation("FmeaEventActor", fields: [actorId], references: [id])
  metadata  Json?
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([fmeaId, createdAt])
  @@map("fmea_events")
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String
  module    String
  createdAt DateTime @default(now())

  @@unique([email, module])
  @@map("waitlist")
}

model FieldDefect {
  id                    String              @id @default(uuid())
  title                 String
  description           String
  source                FieldDefectSource   @default(FIELD)
  status                FieldDefectStatus   @default(DRAFT)
  severity              FieldDefectSeverity @default(MAJOR)
  safetyImpact          Boolean             @default(false) @map("safety_impact")
  vehicleDown           Boolean             @default(false) @map("vehicle_down")
  repeatIssue           Boolean             @default(false) @map("repeat_issue")
  vin                   String?             @map("vin")
  vehicleModel          String?             @map("vehicle_model")
  vehicleVariant        String?             @map("vehicle_variant")
  mileage               Int?               @map("mileage")
  failureDate           DateTime?           @map("failure_date")
  reportDate            DateTime            @default(now()) @map("report_date")
  location              String?             @map("location")
  partNumber            String?             @map("part_number")
  partName              String?             @map("part_name")
  supplierId            String?             @map("supplier_id")
  supplier              Company?            @relation("FieldDefectSupplier", fields: [supplierId], references: [id])
  supplierNameSnapshot  String?             @map("supplier_name_snapshot")
  oemId                 String              @map("oem_id")
  oem                   Company             @relation("FieldDefectOem", fields: [oemId], references: [id])
  createdById           String              @map("created_by_id")
  createdBy             User                @relation("FieldDefectCreatedBy", fields: [createdById], references: [id])
  updatedById           String?             @map("updated_by_id")
  updatedBy             User?               @relation("FieldDefectUpdatedBy", fields: [updatedById], references: [id])
  linkedDefectId        String?             @unique @map("linked_defect_id")
  linkedDefect          Defect?             @relation(fields: [linkedDefectId], references: [id])
  convertedTo8DAt       DateTime?           @map("converted_to_8d_at")
  convertedById         String?             @map("converted_by_id")
  convertedBy           User?               @relation("FieldDefectConvertedBy", fields: [convertedById], references: [id])
  attachments           FieldDefectAttachment[]
  events                FieldDefectEvent[]
  comments              FieldDefectComment[]
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  deletedAt             DateTime?           @map("deleted_at")

  @@index([oemId, status])
  @@index([supplierId, status])
  @@index([severity])
  @@index([vin])
  @@index([createdAt])
  @@index([linkedDefectId])
  @@map("field_defects")
}

model FieldDefectAttachment {
  id              String            @id @default(cuid())
  fieldDefectId   String            @map("field_defect_id")
  fieldDefect     FieldDefect       @relation(fields: [fieldDefectId], references: [id], onDelete: Cascade)
  storageKey      String            @map("storage_key")
  fileName        String            @map("file_name")
  mimeType        String            @map("mime_type")
  fileSize        Int               @map("file_size")
  uploadedById    String            @map("uploaded_by_id")
  uploadedBy      User              @relation("FieldDefectAttachmentUploadedBy", fields: [uploadedById], references: [id])
  companyId       String            @map("company_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  deletedAt       DateTime?         @map("deleted_at")

  @@index([fieldDefectId])
  @@index([companyId, createdAt])
  @@map("field_defect_attachments")
}

model FieldDefectComment {
  id              String          @id @default(uuid())
  fieldDefectId   String          @map("field_defect_id")
  fieldDefect     FieldDefect     @relation(fields: [fieldDefectId], references: [id], onDelete: Cascade)
  authorId        String          @map("author_id")
  author          User            @relation("FieldDefectCommentAuthor", fields: [authorId], references: [id])
  content         String
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([fieldDefectId, createdAt])
  @@map("field_defect_comments")
}

model FieldDefectEvent {
  id              String          @id @default(uuid())
  fieldDefectId   String          @map("field_defect_id")
  fieldDefect     FieldDefect     @relation(fields: [fieldDefectId], references: [id], onDelete: Cascade)
  type            DefectEventType
  actorId         String?         @map("actor_id")
  actor           User?           @relation("FieldDefectEventActor", fields: [actorId], references: [id])
  metadata        Json?
  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([fieldDefectId, createdAt])
  @@map("field_defect_events")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  type      NotificationType
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}
